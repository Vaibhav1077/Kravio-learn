# ============================================
# Kravio Learn — Frontend Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# For Vercel: add these in Project Settings → Environment Variables.
# ============================================

# Backend API URL (no trailing slash)
# Local: http://localhost:4000/api/v1
# Production: https://your-render-backend-url.onrender.com/api/v1
REACT_APP_BASE_URL=http://localhost:4000/api/v1

# Razorpay (public key only — safe to expose in frontend)
# Get from: https://dashboard.razorpay.com/app/keys
REACT_APP_RAZORPAY_KEY=
