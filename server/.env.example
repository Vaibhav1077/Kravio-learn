# ============================================
# Kravio Learn — Backend Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================

# Server
PORT=4000
NODE_ENV=development

# Frontend URL (used for CORS and password reset emails)
FRONTEND_URL=http://localhost:3000

# MongoDB Atlas
# Get from: https://cloud.mongodb.com → Database → Connect → Drivers
MONGODB_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>

# JWT Authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Cloudinary (Media uploads)
# Get from: https://console.cloudinary.com/settings/api-keys
CLOUD_NAME=
API_KEY=
API_SECRET=
FOLDER_NAME=Kravio

# Mail (SMTP via Brevo)
# Get from: https://app.brevo.com → Settings → SMTP & API → SMTP
MAIL_HOST=smtp-relay.brevo.com
MAIL_USER=
MAIL_PASS=

# Razorpay (Payments)
# Get from: https://dashboard.razorpay.com/app/keys (use Test Mode)
RAZORPAY_KEY=
RAZORPAY_SECRET=
